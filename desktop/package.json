{
	"name": "liminal-builder-desktop",
	"version": "0.1.0",
	"private": true,
	"main": "dist/main/index.js",
	"scripts": {
		"dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:main\" \"bun run dev:electron\"",
		"dev:renderer": "vite --config vite.renderer.config.ts",
		"dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
		"dev:electron": "wait-on tcp:5173 file:dist/main/index.js file:dist/preload/index.js && cross-env DESKTOP_RENDERER_DEV_URL=http://127.0.0.1:5173 electronmon dist/main/index.js",
		"build": "bun run build:renderer && bun run build:main",
		"build:renderer": "vite build --config vite.renderer.config.ts",
		"build:main": "tsc -p tsconfig.node.json",
		"start": "cross-env NODE_ENV=production electron dist/main/index.js",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json --noEmit"
	},
	"dependencies": {
		"@tanstack/react-virtual": "^3.13.12",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-markdown": "^9.0.1",
		"rehype-highlight": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1"
	},
	"devDependencies": {
		"@testing-library/react": "^16.2.0",
		"@types/node": "^24.3.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^5.0.2",
		"concurrently": "^9.2.1",
		"cross-env": "^7.0.3",
		"electron": "^37.5.1",
		"electronmon": "^2.0.2",
		"jsdom": "^28.0.0",
		"typescript": "^5.9.2",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"wait-on": "^8.0.5"
	}
}
